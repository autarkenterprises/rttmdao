# Copy to .env.local for `npm run dev` / production build.
# Pool addresses (required for each chain you use)
VITE_POOL_SEPOLIA=0x0000000000000000000000000000000000000000
VITE_POOL_MAINNET=0x0000000000000000000000000000000000000000

# Optional: deployment block to speed up event queries
# VITE_FROM_BLOCK_SEPOLIA=0
# VITE_FROM_BLOCK_MAINNET=0

# Optional RPC overrides (otherwise wagmi public defaults)
# VITE_RPC_SEPOLIA=
# VITE_RPC_MAINNET=

# GitHub Pages project site (if not user/org root pages)
# VITE_BASE=/rttmdao/
