[Unit]
Description=RttM pool chain indexer (HTTP JSON)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=/etc/default/rttm-indexer
WorkingDirectory=/opt/rttmdao/apps/indexer
ExecStart=/usr/bin/node dist/server.js
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
